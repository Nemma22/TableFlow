# =========================================================================
# TableFlow Environment Variables Template
# Copy this file to .env and fill in your actual private credentials.
# =========================================================================

# ----------------------------------------
# 1. API Keys & Models configuration
# ----------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here
EMBEDDING_MODEL=openai/text-embedding-3-small

# ----------------------------------------
# 2. Database Connection
# ----------------------------------------
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=your_supabase_postgresql_connection_string_here

# ----------------------------------------
# 3. ngrok Configuration (Webhook Tunnels)
# ----------------------------------------
NGROK_AUTHTOKEN=your_ngrok_auth_token_here
